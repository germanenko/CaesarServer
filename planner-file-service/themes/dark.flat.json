{
  "id": "dark",
  "extends": "base",
  "colors": {
    "color.text.primary": "#FFFFFF",
    "color.text.secondary": "#9CA3AF",
    "color.background.main": "#0B0F14",
    "color.header": "#111823",
    "color.action.primary": "#9AA7B6",
    "color.action.secondary": "#10B981",
    "color.button.primary.background": "#3B82F6",
    "color.button.primary.text": "#FFFFFF"
  },
  "icons": {
    "icon.action.search": "SearchIcon",
    "icon.action.settings": "SettingsIcon",
    "icon.navigation.home": "HomeIcon",
    "icon.navigation.back": "BackIcon",
    "icon.navigation.settings": "SettingsIcon",
    "icon.navigation.analytics": "AnalyticsIcon",
    "icon.navigation.teamManagement": "TeamIcon"
  },
  "typography": {
    "font.body.regular": {
      "font": "Inter-Regular",
      "size": 16,
      "weight": 400,
      "lineHeight": 1.5
    },
    "font.body.bold": {
      "font": "Inter-Bold",
      "size": 16,
      "weight": 700,
      "lineHeight": 1.5
    },
    "font.heading.large": {
      "font": "Inter-ExtraBold",
      "size": 32,
      "weight": 600,
      "lineHeight": 1.2
    },
    "font.heading.small": {
      "font": "Inter-Light",
      "size": 24,
      "weight": 500,
      "lineHeight": 1.3
    }
  },
  "spacing": {
    "spacing.primary": 12,
    "spacing.secondary": 15
  },
  "radii": {
    "radius.primary": 15,
    "radius.secondary": 12
  }
}