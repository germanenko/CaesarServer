{
  "id": "light",
  "extends": "base",
  "colors": {
    "text.primary": "#111827",
    "text.secondary": "#6B7280",
    "background.main": "#FFFFFF",
    "action.primary": "#2563EB",
    "action.secondary": "#059669",
    "button.primary.background": "#2563EB",
    "button.primary.text": "#111827"
  },
  "icons": {
    "action.search": "SearchIcon",
    "action.settings": "SettingsIcon",
    "navigation.home": "HomeIcon",
    "navigation.back": "BackIcon"
  },
  "fonts": {
    "body.regular": {
      "font": "Inter-Regular",
      "size": 16,
      "weight": 400,
      "lineHeight": 1.5
    },
    "body.bold": {
      "font": "Inter-Bold",
      "size": 16,
      "weight": 700,
      "lineHeight": 1.5
    },
    "heading.large": {
      "font": "Inter-ExtraBold",
      "size": 32,
      "weight": 600,
      "lineHeight": 1.2
    },
    "heading.small": {
      "font": "Inter-Light",
      "size": 24,
      "weight": 500,
      "lineHeight": 1.3
    }
  },
  "spacing": {
    "spacing.primary": 12,
    "spacing.secondary": 15
  },
  "radii": {
    "radius.primary": 15,
    "radius.secondary": 12
  }
}