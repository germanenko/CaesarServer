FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build-env
WORKDIR /App

COPY ../NuGet.config .
COPY ../nuget-local ./nuget-local
COPY . .

RUN dotnet restore planner-file-service/planner_file_service.sln
RUN dotnet publish \
  planner-file-service/src/planner_file_service.Api/planner_file_service.Api.csproj \
  -c Release -o /App/out

# Копирование файлов тем (простой способ)
RUN mkdir -p /default-themes
# Используем find для копирования
RUN find . -maxdepth 2 -name "*.flat.json" -exec cp {} /default-themes/ \; || true

# Финальный образ
FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /App

ENV FILE_SERVER_STORAGE_PATH=/file-storage

RUN mkdir -p ${FILE_SERVER_STORAGE_PATH}

COPY --from=build-env /App/out .
COPY --from=build-env /default-themes/*.flat.json ${FILE_SERVER_STORAGE_PATH}/ 2>/dev/null || true

ENTRYPOINT ["dotnet", "planner_file_service.Api.dll"]