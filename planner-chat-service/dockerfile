FROM mcr.microsoft.com/dotnet/sdk:7.0 AS build-env
WORKDIR /App

COPY ../NuGet.config .
COPY ../nuget-local ./nuget-local
COPY key.json .
COPY . .

RUN dotnet restore planner-chat-service/planner_chat_service.sln

RUN dotnet publish \
  planner-chat-service/src/planner_chat_service.Api/planner_chat_service.Api.csproj \
  -c Release -o /App/out


FROM mcr.microsoft.com/dotnet/aspnet:7.0
WORKDIR /App
COPY --from=build-env /App/out .
COPY --from=build-env /App/key.json .

RUN ls -la /App/ && \
    echo "=== Checking key.json ===" && \
    if [ -f /App/key.json ]; then \
        echo "key.json exists in final image"; \
        ls -la /App/key.json; \
    else \
        echo "WARNING: key.json NOT found in final image!"; \
    fi

ENTRYPOINT ["dotnet", "planner_chat_service.Api.dll"]