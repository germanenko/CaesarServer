FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build-env
WORKDIR /App

# NuGet
COPY ../NuGet.config .
COPY ../nuget-local ./nuget-local

# solution
COPY planner-node-service/planner_node_service.sln .

# restore cache layer (все проекты)
COPY planner-node-service/src/planner_node_service.Api/*.csproj ./src/planner_node_service.Api/
COPY planner-node-service/src/planner_node_service.App/*.csproj ./src/planner_node_service.App/
COPY planner-node-service/src/planner_node_service.Core/*.csproj ./src/planner_node_service.Core/
COPY planner-node-service/src/planner_node_service.Infrastructure/*.csproj ./src/planner_node_service.Infrastructure/

RUN dotnet restore planner_node_service.sln

# copy full source
COPY planner-node-service ./planner-node-service

# publish
RUN dotnet publish \
  planner-node-service/src/planner_node_service.Api/planner_node_service.Api.csproj \
  -c Release \
  -o /App/out \
  /p:UseAppHost=false \
  /p:DebugType=None \
  /p:DebugSymbols=false \
  /p:InvariantGlobalization=true

# runtime
FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /App
COPY --from=build-env /App/out .
ENTRYPOINT ["dotnet", "planner_node_service.Api.dll"]